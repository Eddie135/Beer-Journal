{
  "appId": "com.mybeerjournal.app",
  "appName": "Beer Journal",
  "webDir": "web",
  "android": {
    "backgroundColor": "#F7F7F5"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 0,
      "launchAutoHide": true,
      "backgroundColor": "#F7F7F5",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "LIGHT",
      "backgroundColor": "#00000000",
      "overlaysWebView": true
    }
  }
}
