apply plugin: 'com.android.application'

def releaseKeystoreProperties = new Properties()
def releaseKeystoreFile = rootProject.file('keystore.properties')
if (releaseKeystoreFile.exists()) {
    releaseKeystoreFile.withInputStream { releaseKeystoreProperties.load(it) }
}

def resolvedVersionCode = (project.findProperty("versionCode") ?: "30").toInteger()
def resolvedVersionName = project.findProperty("versionName") ?: "1.0.0-rc2-fix8"

android {
    namespace = "com.mybeerjournal.app"
    compileSdk = rootProject.ext.compileSdkVersion
    // Internal user-test builds are the safe default. A formal package must
    // be requested explicitly with -Pv1Test=false.
    def v1Test = project.hasProperty("v1Test") ? project.property("v1Test").toString().toBoolean() : true
    def resolvedApplicationId = v1Test ? "com.mybeerjournal.app.v1test" : "com.mybeerjournal.app"
    defaultConfig {
        applicationId resolvedApplicationId
        minSdkVersion rootProject.ext.minSdkVersion
        targetSdkVersion rootProject.ext.targetSdkVersion
        versionCode resolvedVersionCode
        versionName resolvedVersionName
        testInstrumentationRunner "androidx.test.runner.AndroidJUnitRunner"
        aaptOptions {
             // Files and dirs to omit from the packaged assets dir, modified to accommodate modern web apps.
             // Default: https://android.googlesource.com/platform/frameworks/base/+/282e181b58cf72b6ca770dc7ca5f91f135444502/tools/aapt/AaptAssets.cpp#61
            ignoreAssetsPattern = '!.svn:!.git:!.ds_store:!*.scc:.*:!CVS:!thumbs.db:!picasa.ini:!*~'
        }
    }
    buildTypes {
        release {
            minifyEnabled false
            proguardFiles getDefaultProguardFile('proguard-android.txt'), 'proguard-rules.pro'
            signingConfig signingConfigs.release
        }
    }
    signingConfigs {
        release {
            def storeFilePath = releaseKeystoreProperties['storeFile'] ?: System.getenv('BEER_JOURNAL_RELEASE_STORE_FILE')
            def storePasswordValue = releaseKeystoreProperties['storePassword'] ?: System.getenv('BEER_JOURNAL_RELEASE_STORE_PASSWORD')
            def keyAliasValue = releaseKeystoreProperties['keyAlias'] ?: System.getenv('BEER_JOURNAL_RELEASE_KEY_ALIAS')
            def keyPasswordValue = releaseKeystoreProperties['keyPassword'] ?: System.getenv('BEER_JOURNAL_RELEASE_KEY_PASSWORD')
            if (storeFilePath && storePasswordValue && keyAliasValue && keyPasswordValue) {
                storeFile file(storeFilePath)
                storePassword storePasswordValue
                keyAlias keyAliasValue
                keyPassword keyPasswordValue
            } else if (gradle.startParameter.taskNames.any { it.toLowerCase().contains('release') }) {
                throw new GradleException('Release signing is not configured. Provide mobile/android/keystore.properties or BEER_JOURNAL_RELEASE_* environment variables.')
            }
        }
    }
}

android.applicationVariants.all { variant ->
    if (variant.name == "debug") {
        variant.outputs.all { output ->
        def internalBuild = project.hasProperty("v1Test") ? project.property("v1Test").toString().toBoolean() : true
        def defaultApkName = internalBuild
            ? "Beer-Journal-v1.0.0-rc2-fix8-user-test-debug.apk"
            : "Beer-Journal-${resolvedVersionName}.apk"
        output.outputFileName = project.findProperty("apkName") ?: defaultApkName
        }
    }
}

repositories {
    flatDir{
        dirs '../capacitor-cordova-android-plugins/src/main/libs', 'libs'
    }
}

dependencies {
    implementation fileTree(include: ['*.jar'], dir: 'libs')
    implementation "androidx.appcompat:appcompat:$androidxAppCompatVersion"
    implementation "androidx.coordinatorlayout:coordinatorlayout:$androidxCoordinatorLayoutVersion"
    implementation "androidx.core:core-splashscreen:$coreSplashScreenVersion"
    implementation project(':capacitor-android')
    testImplementation "junit:junit:$junitVersion"
    androidTestImplementation "androidx.test.ext:junit:$androidxJunitVersion"
    androidTestImplementation "androidx.test.espresso:espresso-core:$androidxEspressoCoreVersion"
    implementation project(':capacitor-cordova-android-plugins')
}

apply from: 'capacitor.build.gradle'

try {
    def servicesJSON = file('google-services.json')
    if (servicesJSON.text) {
        apply plugin: 'com.google.gms.google-services'
    }
} catch(Exception e) {
    logger.info("google-services.json not found, google-services plugin not applied. Push Notifications won't work")
}
