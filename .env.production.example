# 复制到 Debian 服务器的 /srv/beer-journal/.env.production 后再填写真实值。
# 这个示例只能作为字段清单，绝不能直接用于生产。

# Compose
COMPOSE_PROJECT_NAME=beer-journal
APP_IMAGE_TAG=production
POSTGRES_IMAGE=postgres:17-alpine
NGINX_IMAGE=nginx:stable-alpine
GUNICORN_WORKERS=1
HTTP_PORT=80
HTTPS_PORT=443
NGINX_CONFIG_TEMPLATE=beer-journal.http.conf.template

# Django：真实 SECRET_KEY 必须在服务器生成，不能提交到 Git。
SECRET_KEY=replace-with-a-long-random-server-generated-secret
DEBUG=0
ALLOWED_HOSTS=beer.example.com
CSRF_TRUSTED_ORIGINS=https://beer.example.com
DOMAIN_NAME=beer.example.com
CLIENT_MAX_BODY_SIZE=12m
DJANGO_STATIC_ROOT=/app/static
DJANGO_MEDIA_ROOT=/app/media
DJANGO_SECURE_PROXY_SSL_HEADER=1
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SESSION_COOKIE_SECURE=1
DJANGO_CSRF_COOKIE_SECURE=1
# 首次 HTTPS 验证完成后才改为 31536000；启用后浏览器会记住 HTTPS。
DJANGO_HSTS_SECONDS=0
DJANGO_HSTS_INCLUDE_SUBDOMAINS=0
DJANGO_HSTS_PRELOAD=0

# DATABASE_URL 是生产配置的统一连接描述；当前 Django 设置尚未读取它。
# 密码中的特殊字符必须进行 URL 编码。
DATABASE_URL=postgresql://beer_journal:replace-with-url-encoded-password@postgres:5432/beer_journal

# 当前 Django 设置实际使用的 PostgreSQL 字段。
POSTGRES_DB=beer_journal
POSTGRES_USER=beer_journal
POSTGRES_PASSWORD=replace-with-a-long-random-database-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
