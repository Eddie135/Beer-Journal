# 首次申请证书前使用：仅开放 ACME 校验路径，不通过 HTTP 提供私人页面。
server {
    listen 80;
    listen [::]:80;
    server_name ${DOMAIN_NAME};
    server_tokens off;
    client_max_body_size ${CLIENT_MAX_BODY_SIZE};

    location ^~ /.well-known/acme-challenge/ {
        root /var/www/certbot;
        default_type "text/plain";
    }

    location / {
        return 503;
    }
}
